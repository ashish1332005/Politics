
# Atlas example. URL-encode special characters in username/password, e.g. p@123 becomes p%40123.
MONGO_URI=mongodb+srv://Politic:Shree123@cluster0.xcvnrhw.mongodb.net/political_crm?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
PORT=5000
MAX_UPLOAD_MB=250
UPLOAD_TIMEOUT_MINUTES=30
UPLOAD_PATH=uploads
CORS_ORIGIN=*
APP_PUBLIC_URL=http://localhost:5000
ALLOW_PUBLIC_REGISTER=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123
PDFIMAGES_PATH=C:\poppler-26.02.0\Library\bin\pdfimages.exe
PDFTOPPM_PATH=C:\poppler-26.02.0\Library\bin\pdftoppm.exe
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSDATA_PREFIX=.\tessdata
IMAGEMAGICK_PATH=C:\Program Files\ImageMagick-7.1.1-Q16-HDRI\magick.exe
OCR_LANGUAGES=hin+eng
OCR_DPI=300
OCR_PSM=6
VOTER_GRID_COLUMNS=3
VOTER_GRID_ROWS=10
VOTER_GRID_LEFT_RATIO=0.02
VOTER_GRID_HEADER_RATIO=0.03
VOTER_GRID_CARD_WIDTH_RATIO=0.288
VOTER_GRID_CARD_HEIGHT_RATIO=0.088
VOTER_GRID_GAP_X_RATIO=0.006
VOTER_GRID_GAP_Y_RATIO=0.005
VOTER_GRID_FOOTER_RATIO=0.025
