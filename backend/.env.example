VOTER_PHOTO_HEIGHT_RATIO=0.63
VOTER_PAGE_MIN_LABELS=5
VOTER_CELL_OCR_PSM=6
OCR_CELL_CONCURRENCY=4
IMAGE_CROP_CONCURRENCY=6
OCR_CARD_WIDTH=1350
OCR_THRESHOLD=68
USE_PYTHON_OCR=true
PYTHON_PATH=python
OCR_MIN_CONFIDENCE=35
